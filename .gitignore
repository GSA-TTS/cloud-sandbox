# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# CSB broker environment files — contain secrets; NEVER commit these
scripts/envs/*.env
# Allow the example/template files
!scripts/envs/*.env.example

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Typescript v1 declaration files
typings/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# dotenv environment variable files
.env*

# TruffleHog / gitleaks temporary report output
trufflehog-report*.json
gitleaks-report*.json

# Temporary GCP service account key files (should never persist to disk)
*-sa-key.json
/tmp/*.json

# CF manifest overrides with injected secrets
scripts/manifests/*-secret*.yml

# gatsby files
.cache/
public
_site

# Mac files
.DS_Store

# Yarn
yarn-error.log
.pnp/
.pnp.js
# Yarn Integrity file
.yarn-integrity
