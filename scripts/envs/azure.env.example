# ─────────────────────────────────────────────────────────────────────────────
# CSB Azure Brokerpak — Environment Variables
# Copy this file to scripts/envs/azure.env and fill in your values.
# NEVER commit scripts/envs/azure.env — it is git-ignored.
#
# CREDENTIAL PROVISIONING GUIDE (brew install → auth → service principal → this file):
#   docs/credential-provisioning.md  §  Azure — azd + az
# ─────────────────────────────────────────────────────────────────────────────

# ── Broker Identity ──────────────────────────────────────────────────────────
SECURITY_USER_NAME=csb-azure-broker
SECURITY_USER_PASSWORD=CHANGEME-strong-password

# ── CF App Name & Broker Registration ────────────────────────────────────────
APP_NAME=csb-azure
BROKER_NAME=csb-azure-sandbox
MYSQL_INSTANCE=csb-sql

# ── Azure Service Principal Credentials ──────────────────────────────────────
# Provided by TechOps for the sandbox Azure subscription.
# The SP needs Contributor + User Access Administrator on the sandbox subscription,
# scoped only to the dedicated sandbox resource group where applicable.
ARM_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ARM_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ARM_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ARM_CLIENT_SECRET=CHANGEME-sp-secret

# Optional: override default location (default eastus)
# ARM_LOCATION=eastus

# ── Sandbox-8h Plan Definitions ───────────────────────────────────────────────
# Note: Azure does not use GSB_SERVICE_* plan env vars in the same way;
# plan overrides are passed via manifest env vars loaded by push-broker.sh.
# These are included here for documentation and future CSB plan-override support.

# csb-azure-postgresql — Flexible Server B1ms, no zone redundancy
CSB_AZURE_POSTGRESQL_PLAN='[{
  "name": "sandbox-8h",
  "id": "c5gfge90-2g6c-5c7g-bd5g-200000000001",
  "description": "Sandbox Azure PostgreSQL Flexible Server B1ms — no HA, 8h TTL",
  "free": true,
  "properties": {
    "sku_name": "Standard_B1ms",
    "storage_mb": 32768,
    "postgres_version": "15",
    "high_availability": "Disabled",
    "zone_redundant_standby": false,
    "backup_retention_days": 7,
    "geo_redundant_backup": false
  }
}]'

# csb-azure-mssql — Basic 2 DTU, no geo-replication
CSB_AZURE_MSSQL_PLAN='[{
  "name": "sandbox-8h",
  "id": "c5gfge90-2g6c-5c7g-bd5g-200000000002",
  "description": "Sandbox Azure SQL Basic 2 DTU — no geo-replication, 8h TTL",
  "free": true,
  "properties": {
    "sku_name": "Basic",
    "sku_tier": "Basic",
    "sku_capacity": 2,
    "max_storage_gb": 2,
    "enable_threat_detection_policy": false,
    "geo_redundant_backup": false
  }
}]'

# csb-azure-redis — C0 Basic, no clustering
CSB_AZURE_REDIS_PLAN='[{
  "name": "sandbox-8h",
  "id": "c5gfge90-2g6c-5c7g-bd5g-200000000003",
  "description": "Sandbox Azure Redis Cache C0 Basic — no clustering, 8h TTL",
  "free": true,
  "properties": {
    "sku_name": "Basic",
    "family": "C",
    "capacity": 0,
    "enable_non_ssl_port": false,
    "shard_count": 0,
    "zones": []
  }
}]'

# csb-azure-storage-account — LRS only
CSB_AZURE_STORAGE_PLAN='[{
  "name": "sandbox-8h",
  "id": "c5gfge90-2g6c-5c7g-bd5g-200000000004",
  "description": "Sandbox Azure Storage LRS — no RA-GRS, 8h TTL",
  "free": true,
  "properties": {
    "account_replication_type": "LRS",
    "account_kind": "StorageV2",
    "access_tier": "Hot",
    "enable_https_traffic_only": true,
    "min_tls_version": "TLS1_2"
  }
}]'

# csb-azure-eventhubs — Basic namespace, 1 TU
CSB_AZURE_EVENTHUBS_PLAN='[{
  "name": "sandbox-8h",
  "id": "c5gfge90-2g6c-5c7g-bd5g-200000000005",
  "description": "Sandbox Azure Event Hubs Basic 1 TU — 8h TTL",
  "free": true,
  "properties": {
    "sku": "Basic",
    "capacity": 1,
    "auto_inflate_enabled": false,
    "zone_redundant": false
  }
}]'

# ── Global Provision Defaults ─────────────────────────────────────────────────
GSB_PROVISION_DEFAULTS='{"location": "eastus", "resource_group": "csb-sandbox-dev"}'

# ── CredHub (optional) ────────────────────────────────────────────────────────
# CH_CRED_HUB_URL=https://credhub.service.cf.internal:8844
# CH_UAA_URL=https://uaa.service.cf.internal:8443
# CH_UAA_CLIENT_NAME=credhub_admin_client
# CH_UAA_CLIENT_SECRET=CHANGEME
