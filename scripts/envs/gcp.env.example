# ─────────────────────────────────────────────────────────────────────────────
# CSB GCP Brokerpak — Environment Variables
# Copy this file to scripts/envs/gcp.env and fill in your values.
# NEVER commit scripts/envs/gcp.env — it is git-ignored.
#
# CREDENTIAL PROVISIONING GUIDE (brew install → auth → SA → key → this file):
#   docs/credential-provisioning.md  §  GCP — gcloud
# ─────────────────────────────────────────────────────────────────────────────

# ── Broker Identity ──────────────────────────────────────────────────────────
SECURITY_USER_NAME=csb-gcp-broker
SECURITY_USER_PASSWORD=CHANGEME-strong-password

# ── CF App Name & Broker Registration ────────────────────────────────────────
APP_NAME=csb-gcp
BROKER_NAME=csb-gcp-sandbox
MYSQL_INSTANCE=csb-sql

# ── GCP Credentials ──────────────────────────────────────────────────────────
# Full JSON content of the service account key file (Owner role on sandbox project).
# See submodules/csb-brokerpak-gcp/docs/installation.md for SA setup steps.
# Wrap the entire JSON in single quotes; escape any internal single quotes.
GOOGLE_CREDENTIALS='{ "type": "service_account", "project_id": "YOUR_PROJECT_ID", "private_key_id": "KEY_ID", "private_key": "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n", "client_email": "csb@YOUR_PROJECT_ID.iam.gserviceaccount.com", "client_id": "CLIENT_ID", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token" }'

# GCP project ID for the dedicated sandbox project
GOOGLE_PROJECT=YOUR_GCP_SANDBOX_PROJECT_ID

# Optional: override default GCP region (default us-central1)
# CSB_GCP_REGION=us-central1

# ── Sandbox-8h Plan Definitions ───────────────────────────────────────────────
GSB_SERVICE_CSB_GOOGLE_POSTGRES_PLANS='[{
  "name": "sandbox-8h",
  "id": "b4fefd89-1f5b-4b6f-ac4f-100000000001",
  "description": "Sandbox Cloud SQL PostgreSQL db-f1-micro — no HA/PITR, 8h TTL",
  "free": true,
  "properties": {
    "tier": "db-f1-micro",
    "disk_size": 10,
    "disk_type": "PD_SSD",
    "availability_type": "ZONAL",
    "backups_enabled": false,
    "point_in_time_recovery_enabled": false,
    "highly_available": false,
    "postgres_version": "POSTGRES_15"
  }
}]'

GSB_SERVICE_CSB_GOOGLE_MYSQL_PLANS='[{
  "name": "sandbox-8h",
  "id": "b4fefd89-1f5b-4b6f-ac4f-100000000002",
  "description": "Sandbox Cloud SQL MySQL db-f1-micro — no HA, 8h TTL",
  "free": true,
  "properties": {
    "tier": "db-f1-micro",
    "disk_size": 10,
    "disk_type": "PD_SSD",
    "availability_type": "ZONAL",
    "backups_enabled": false,
    "highly_available": false,
    "mysql_version": "MYSQL_8_0"
  }
}]'

GSB_SERVICE_CSB_GOOGLE_STORAGE_BUCKET_PLANS='[{
  "name": "sandbox-8h",
  "id": "b4fefd89-1f5b-4b6f-ac4f-100000000003",
  "description": "Sandbox GCS bucket — uniform ACL, 10-day lifecycle delete, 8h TTL",
  "free": true,
  "properties": {
    "storage_class": "STANDARD",
    "uniform_bucket_level_access": true,
    "versioning": false,
    "lifecycle_rules": [{"action": {"type": "Delete"}, "condition": {"age": 10}}]
  }
}]'

# ── Global Provision Defaults ─────────────────────────────────────────────────
GSB_PROVISION_DEFAULTS='{"region": "us-central1"}'

# ── CredHub (optional) ────────────────────────────────────────────────────────
# CH_CRED_HUB_URL=https://credhub.service.cf.internal:8844
# CH_UAA_URL=https://uaa.service.cf.internal:8443
# CH_UAA_CLIENT_NAME=credhub_admin_client
# CH_UAA_CLIENT_SECRET=CHANGEME
