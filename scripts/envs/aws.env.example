# ─────────────────────────────────────────────────────────────────────────────
# CSB AWS Brokerpak — Environment Variables
# Copy this file to scripts/envs/aws.env and fill in your values.
# NEVER commit scripts/envs/aws.env — it is git-ignored.
#
# CREDENTIAL PROVISIONING GUIDE (brew install → auth → IAM → creds → this file):
#   docs/credential-provisioning.md  §  AWS — aws-cli
# All credentials are injected into CF via cf-manifest at deploy time;
# they are NOT stored in the app environment long-term — use CredHub bindings
# for production deployments.
# ─────────────────────────────────────────────────────────────────────────────

# ── Broker Identity ──────────────────────────────────────────────────────────
# Username/password used when registering the CF service broker
SECURITY_USER_NAME=csb-aws-broker
SECURITY_USER_PASSWORD=CHANGEME-strong-password

# ── CF App Name & Broker Registration ────────────────────────────────────────
APP_NAME=csb-aws
BROKER_NAME=csb-aws-sandbox
# Name of the MySQL service instance used for broker state storage
MYSQL_INSTANCE=csb-sql

# ── AWS Credentials ──────────────────────────────────────────────────────────
# Provided by TechOps for the sandbox AWS account.
# The IAM user/role must have the permissions documented in
# submodules/csb-brokerpak-aws/docs/installation.md
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# Optional: override default region (default in sandbox plans is us-east-1)
# AWS_DEFAULT_REGION=us-east-1

# ── VPC for provisioned resources (required for RDS/ElastiCache) ─────────────
# AWS VPC ID where sandbox resources will be placed
AWS_PAS_VPC_ID=vpc-XXXXXXXX

# ── Sandbox-8h Plan Definitions ───────────────────────────────────────────────
# These override the default plans shipped with the brokerpak.
# Only sandbox-8h plans are exposed; all others are omitted.
# Plan IDs are stable UUIDs — do not change them after initial deployment.

GSB_SERVICE_CSB_AWS_S3_BUCKET_PLANS='[{
  "name": "sandbox-8h",
  "id": "a3edfd78-0e4f-4a5e-9b3e-000000000001",
  "description": "Sandbox S3 bucket — private ACL, no versioning, 8h TTL",
  "free": true,
  "properties": {
    "acl": "private",
    "versioning": false,
    "brokered_enables_versioning": false
  }
}]'

GSB_SERVICE_CSB_AWS_POSTGRESQL_PLANS='[{
  "name": "sandbox-8h",
  "id": "a3edfd78-0e4f-4a5e-9b3e-000000000002",
  "description": "Sandbox RDS PostgreSQL db.t3.micro — no multi-AZ, 8h TTL",
  "free": true,
  "properties": {
    "instance_class": "db.t3.micro",
    "storage_gb": 10,
    "storage_type": "gp2",
    "multi_az": false,
    "auto_minor_version_upgrade": true,
    "deletion_protection": false,
    "postgres_version": "16"
  }
}]'

GSB_SERVICE_CSB_AWS_MYSQL_PLANS='[{
  "name": "sandbox-8h",
  "id": "a3edfd78-0e4f-4a5e-9b3e-000000000003",
  "description": "Sandbox RDS MySQL db.t3.micro — no multi-AZ, 8h TTL",
  "free": true,
  "properties": {
    "instance_class": "db.t3.micro",
    "storage_gb": 10,
    "storage_type": "gp2",
    "multi_az": false,
    "auto_minor_version_upgrade": true,
    "deletion_protection": false,
    "mysql_version": "8.0"
  }
}]'

GSB_SERVICE_CSB_AWS_REDIS_PLANS='[{
  "name": "sandbox-8h",
  "id": "a3edfd78-0e4f-4a5e-9b3e-000000000004",
  "description": "Sandbox ElastiCache Redis t2.micro single-node, 8h TTL",
  "free": true,
  "properties": {
    "cache_size": 1,
    "node_type": "cache.t2.micro",
    "num_cache_nodes": 1,
    "automatic_failover_enabled": false,
    "at_rest_encryption_enabled": true,
    "transit_encryption_enabled": true
  }
}]'

GSB_SERVICE_CSB_AWS_SQS_PLANS='[{
  "name": "sandbox-8h",
  "id": "a3edfd78-0e4f-4a5e-9b3e-000000000005",
  "description": "Sandbox SQS standard queue, 8h TTL",
  "free": true,
  "properties": {
    "fifo": false,
    "content_based_deduplication": false
  }
}]'

# ── Stub plans for brokerpak services NOT in the sandbox catalog ──────────────
# CSB v2.6.10 requires at least one plan per service that has no built-in plans.
# These stubs are intentionally named "not-available" so they never get used.
# Approved services are listed above with sandbox-8h plans only.
GSB_SERVICE_CSB_AWS_AURORA_POSTGRESQL_PLANS='[{"name":"not-available","id":"a3edfd78-0e4f-4a5e-0000-100000000001","description":"Not available in sandbox","free":false,"properties":{}}]'
GSB_SERVICE_CSB_AWS_AURORA_MYSQL_PLANS='[{"name":"not-available","id":"a3edfd78-0e4f-4a5e-0000-100000000002","description":"Not available in sandbox","free":false,"properties":{}}]'
GSB_SERVICE_CSB_AWS_MSSQL_PLANS='[{"name":"not-available","id":"a3edfd78-0e4f-4a5e-0000-100000000003","description":"Not available in sandbox","free":false,"properties":{}}]'
GSB_SERVICE_CSB_AWS_DYNAMODB_NAMESPACE_PLANS='[{"name":"not-available","id":"a3edfd78-0e4f-4a5e-0000-100000000004","description":"Not available in sandbox","free":false,"properties":{}}]'

# ── Global Provision Defaults ─────────────────────────────────────────────────
# Applied to every provision request; injects required sandbox tags.
GSB_PROVISION_DEFAULTS='{"aws_vpc_id": "vpc-XXXXXXXX"}'

# ── CredHub (optional — cloud.gov internal) ──────────────────────────────────
# Uncomment to enable CredHub credential storage (recommended for production).
# CH_CRED_HUB_URL=https://credhub.service.cf.internal:8844
# CH_UAA_URL=https://uaa.service.cf.internal:8443
# CH_UAA_CLIENT_NAME=credhub_admin_client
# CH_UAA_CLIENT_SECRET=CHANGEME
